# Copy to .env and adjust for your deployment:
#   cp env.example .env
#
# Docker Compose reads .env automatically for variable substitution.

# --- Host port bindings -------------------------------------------------------
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=8080
MQTT_PORT=1883
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

# --- Public URL (no trailing slash) -------------------------------------------
# Used for CORS, OTA firmware URLs, and frontend build-time config.
PUBLIC_URL=https://wbms.autokadir.co.uk
FRONTEND_ORIGIN=https://wbms.autokadir.co.uk
BACKEND_PUBLIC_URL=https://wbms.autokadir.co.uk

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=wbms
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wbms

# --- Application secrets ------------------------------------------------------
WBMS_SECRET_KEY=change-me
OTA_URL_SECRET=change-me-in-production-please

# --- MQTT (must match ESP32 master firmware and mosquitto/config/passwd) ------
MQTT_TOPIC=bms/data
MQTT_USERNAME=wbms-backend
MQTT_PASSWORD=change-me

# --- Google OAuth (must match Google Cloud Console authorized origins) --------
GOOGLE_CLIENT_ID=

# --- BMS topology -------------------------------------------------------------
CONNECTED_CELLS=3
PARALLEL_COUNT=1

# --- EKF worker (optional tuning) ---------------------------------------------
WBMS_LOG_LEVEL=INFO
EKF_POLL_INTERVAL_S=5
EKF_NN_ENABLED=false
EKF_CURRENT_OFFSET_A=0.048
EKF_CURRENT_GAIN=1.030
EKF_CURRENT_DEADBAND_A=0.010
